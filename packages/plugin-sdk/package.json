{
  "name": "@n1creator/openacp-plugin-sdk",
  "version": "2026.720.1",
  "description": "SDK for building OpenACP plugins — types, base classes, and testing utilities",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./formatting": {
      "types": "./dist/formatting.d.ts",
      "import": "./dist/formatting.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "pnpm test:types && tsc",
    "test:types": "tsc -p tsconfig.type-tests.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@n1creator/openacp-cli": ">=2026.720.1",
    "vitest": ">=3 <5"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@n1creator/openacp-cli": "workspace:*",
    "vitest": "^3.2.7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/an1creator/OpenACP.git",
    "directory": "packages/plugin-sdk"
  },
  "homepage": "https://github.com/an1creator/OpenACP",
  "keywords": [
    "openacp",
    "plugin",
    "sdk",
    "testing"
  ],
  "license": "MIT"
}
